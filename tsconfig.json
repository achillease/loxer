{
  // Single ESM build. Emits one modern ES-module tree to dist/. `nodenext` enforces the
  // explicit `.js` import extensions Node's ESM loader needs at runtime.
  // see https://www.typescriptlang.org/tsconfig to better understand tsconfigs
  "include": ["src"],
  "compilerOptions": {
    "incremental": true /* Enable incremental compilation */,
    "target": "ES2022" /* Native classes so Error subclasses satisfy `instanceof`; Node >=20 supports all ES2022 features. */,
    "module": "nodenext" /* ES module output for Node. */,
    "moduleResolution": "nodenext" /* Enforces explicit `.js` import extensions. */,
    "lib": ["ESNext", "DOM"] /* Specify library files to be included in the compilation. */,
    "types": ["node"] /* Include Node ambient types (e.g. `process`) explicitly; pnpm's layout no longer auto-injects them. */,
    "allowJs": true /* Allow javascript files to be compiled. */,
    "declaration": true /* Generates corresponding '.d.ts' file. */,
    "sourceMap": true /* Generates corresponding '.map' file. */,
    "outDir": "dist" /* Redirect output structure to the directory. */,
    "rootDir": "src" /* Root directory of input files, controls the output structure under outDir. */,
    "tsBuildInfoFile": "node_modules/.cache/loxer/tsbuildinfo" /* Keep the incremental cache out of dist/ so it never ships. */,

    /* Strict Type-Checking Options */
    "strict": true /* Enable all strict type-checking options. */,
    "noImplicitAny": true /* Raise error on expressions and declarations with an implied 'any' type. */,
    "strictNullChecks": true /* Enable strict null checks. */,
    "alwaysStrict": true /* Parse in strict mode and emit "use strict" for each source file. */,

    /* Module Resolution Options */
    "esModuleInterop": true /* Emit interoperability between CommonJS and ES Modules. */,

    /* Experimental Options */
    "experimentalDecorators": true /* Enables experimental support for legacy TS decorators. */,

    /* Advanced Options */
    "skipLibCheck": true /* Skip type checking of declaration files. */,
    "forceConsistentCasingInFileNames": true /* Disallow inconsistently-cased references to the same file. */
  },
  "watchOptions": {
    "excludeDirectories": ["**/node_modules"]
  }
}
